---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gustav Jes Iversen',
  jobTitle: 'Developer & AI Engineer',
  url: 'https://gustaviversen.dev',
  sameAs: [
    'https://github.com/Gustavjiversen01',
    'https://www.linkedin.com/in/gustav-jes-iversen-663641218/',
  ],
};
---

<BaseLayout
  title="Gustav Jes Iversen | Developer & AI Engineer"
  description="Personal portfolio and blog. Open source projects, technical writing on ML, AI agents, and autonomous systems."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-bg-primary pt-12 sm:pt-20 pb-20 sm:pb-28">
    <div class="absolute -top-1/2 -right-1/4 w-[600px] h-[600px] rounded-full bg-accent-500/[0.07] blur-[120px]"></div>
    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
        <!-- Left column -->
        <div>
          <h1
            class="font-serif text-3xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold tracking-tight leading-[1.05]"
            style="text-shadow: 0 0 80px rgba(212,168,67,0.15)"
          >
            Gustav Jes Iversen
          </h1>
          <p class="text-gradient text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight mt-2">
            Developer &amp; AI Engineer
          </p>
          <p class="mt-6 text-lg text-text-secondary max-w-2xl leading-relaxed">
            Building AI systems that ship to production. Open source contributor, ML engineer, and cloud infrastructure builder.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              href="/projects/"
              class="btn-glow inline-flex items-center justify-center bg-accent-500 text-bg-primary rounded-lg px-6 py-3 text-sm font-medium hover:bg-accent-400 transition-colors"
            >
              View Projects
            </a>
            <a
              href="/blog/"
              class="inline-flex items-center justify-center border border-border text-text-secondary rounded-lg px-6 py-3 text-sm font-medium hover:text-text-primary hover:border-border-hover transition-colors"
            >
              Read the Blog
            </a>
          </div>
        </div>

        <!-- Right column: Neural network diagram (left-to-right) -->
        <div class="hidden md:block">
          <div class="relative w-full max-w-md mx-auto" style="aspect-ratio: 5/4;">
            <svg viewBox="0 0 500 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <defs>
                <linearGradient id="conn-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="var(--color-accent-400)" />
                  <stop offset="100%" stop-color="var(--color-secondary-400)" />
                </linearGradient>
              </defs>

              {/* Layer x-positions: input=60, hidden1=190, hidden2=320, output=450 */}
              {/* All layers centered vertically around y=200 */}

              {/* Input (3) -> Hidden 1 (5) */}
              {[120, 200, 280].flatMap((y1) =>
                [60, 130, 200, 270, 340].map((y2) => (
                  <line x1="60" y1={y1} x2="190" y2={y2} stroke="url(#conn-grad)" stroke-width="0.7" opacity="0.12" />
                ))
              )}

              {/* Hidden 1 (5) -> Hidden 2 (5) */}
              {[60, 130, 200, 270, 340].flatMap((y1) =>
                [60, 130, 200, 270, 340].map((y2) => (
                  <line x1="190" y1={y1} x2="320" y2={y2} stroke="url(#conn-grad)" stroke-width="0.7" opacity="0.12" />
                ))
              )}

              {/* Hidden 2 (5) -> Output (2) */}
              {[60, 130, 200, 270, 340].flatMap((y1) =>
                [155, 245].map((y2) => (
                  <line x1="320" y1={y1} x2="450" y2={y2} stroke="url(#conn-grad)" stroke-width="0.7" opacity="0.12" />
                ))
              )}

              {/* Input layer - 3 nodes, evenly spaced */}
              {[120, 200, 280].map((y) => (
                <g>
                  <circle cx="60" cy={y} r="16" fill="var(--color-accent-500)" opacity="0.06" />
                  <circle cx="60" cy={y} r="7" fill="var(--color-accent-400)" opacity="0.85" />
                </g>
              ))}

              {/* Hidden layer 1 - 5 nodes */}
              {[60, 130, 200, 270, 340].map((y) => (
                <g>
                  <circle cx="190" cy={y} r="14" fill="var(--color-accent-500)" opacity="0.05" />
                  <circle cx="190" cy={y} r={y === 200 ? 7 : 5.5} fill="var(--color-accent-400)" opacity={y === 200 ? 0.9 : 0.7} />
                </g>
              ))}

              {/* Hidden layer 2 - 5 nodes */}
              {[60, 130, 200, 270, 340].map((y) => (
                <g>
                  <circle cx="320" cy={y} r="14" fill="var(--color-secondary-500)" opacity="0.05" />
                  <circle cx="320" cy={y} r={y === 200 ? 7 : 5.5} fill="var(--color-secondary-400)" opacity={y === 200 ? 0.9 : 0.7} />
                </g>
              ))}

              {/* Output layer - 2 nodes, symmetric */}
              {[155, 245].map((y) => (
                <g>
                  <circle cx="450" cy={y} r="16" fill="var(--color-accent-500)" opacity="0.06" />
                  <circle cx="450" cy={y} r="7" fill="var(--color-accent-400)" opacity="0.85" />
                </g>
              ))}

              {/* Layer labels at top */}
              <text x="60" y="28" text-anchor="middle" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" letter-spacing="0.08em" opacity="0.5">INPUT</text>
              <text x="190" y="28" text-anchor="middle" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" letter-spacing="0.08em" opacity="0.5">HIDDEN</text>
              <text x="320" y="28" text-anchor="middle" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" letter-spacing="0.08em" opacity="0.5">HIDDEN</text>
              <text x="450" y="28" text-anchor="middle" fill="var(--color-text-muted)" font-size="9" font-family="var(--font-sans)" letter-spacing="0.08em" opacity="0.5">OUTPUT</text>
            </svg>

            <!-- Ambient glow -->
            <div class="absolute inset-0 bg-accent-500/[0.03] blur-[80px] rounded-full"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro strip -->
  <Section bg="primary">
    <div class="animate-in">
      <p class="max-w-2xl text-text-secondary leading-relaxed">
        I focus on the intersection of software engineering and artificial intelligence, building
        autonomous agents, ML pipelines, and the cloud infrastructure that powers them. Always
        looking for the next hard problem to solve.
      </p>
      <div class="mt-6 flex flex-wrap gap-2">
        {['AI Agents', 'Machine Learning', 'Cloud Infrastructure', 'Autonomous Systems'].map((pill) => (
          <span class="text-xs rounded-full border border-accent-500/30 bg-accent-500/10 text-accent-400 px-3 py-1">
            {pill}
          </span>
        ))}
      </div>
    </div>
  </Section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <Section bg="secondary">
      <div class="animate-in">
        <h2 class="font-sans text-3xl sm:text-4xl font-bold tracking-tight">Projects</h2>
        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
        <div class="mt-8">
          <a href="/projects/" class="text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors">
            View all projects &rarr;
          </a>
        </div>
      </div>
    </Section>
  )}

  <!-- Latest Posts -->
  {latestPosts.length > 0 && (
    <Section bg="primary">
      <div class="animate-in">
        <h2 class="font-sans text-3xl sm:text-4xl font-bold tracking-tight">From the Blog</h2>
        <div class="mt-8 space-y-6 max-w-3xl">
          {latestPosts.map((post) => (
            <BlogPostCard post={post} />
          ))}
        </div>
        <div class="mt-8">
          <a href="/blog/" class="text-accent-400 hover:text-accent-300 text-sm font-medium transition-colors">
            Read all posts &rarr;
          </a>
        </div>
      </div>
    </Section>
  )}
</BaseLayout>
