---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import TagList from '../../components/TagList.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, description, tags, repo, demo } = entry.data;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${title} | Gustav Jes Iversen`}
  description={description}
>
  <Section>
    <div class="animate-in">
      <a
        href="/projects/"
        class="inline-flex items-center text-sm text-text-muted hover:text-accent-400 transition-colors mb-8"
      >
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to projects
      </a>

      <h1 class="font-sans text-3xl sm:text-5xl font-bold tracking-tight">{title}</h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl leading-relaxed">{description}</p>

      {tags.length > 0 && (
        <div class="mt-6">
          <TagList tags={tags} />
        </div>
      )}

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-glow inline-flex items-center justify-center bg-accent-500 text-bg-primary rounded-lg px-5 py-2.5 text-sm font-medium hover:bg-accent-400 transition-colors"
        >
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          Repository
        </a>
        {demo && (
          <a
            href={demo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center border border-border text-text-secondary rounded-lg px-5 py-2.5 text-sm font-medium hover:text-text-primary hover:border-border-hover transition-colors"
          >
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Live Demo
          </a>
        )}
      </div>
    </div>
  </Section>

  <Section bg="secondary">
    <article
      class="mt-10 prose prose-invert max-w-none prose-headings:font-sans prose-headings:font-bold prose-headings:tracking-tight prose-a:text-accent-400 prose-a:no-underline hover:prose-a:text-accent-300 prose-code:text-accent-300 prose-pre:bg-bg-elevated prose-pre:border prose-pre:border-border prose-blockquote:font-serif prose-blockquote:border-accent-500"
    >
      <Content />
    </article>
  </Section>
</BaseLayout>
