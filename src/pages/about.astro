---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Gustav Jes Iversen',
  jobTitle: 'AI Engineer & Founder',
  url: 'https://gustaviversen.dev/about/',
  alumniOf: [
    {
      '@type': 'CollegeOrUniversity',
      name: 'Technical University of Denmark (DTU)',
    },
    {
      '@type': 'CollegeOrUniversity',
      name: 'University of Copenhagen',
    },
  ],
  knowsAbout: [
    'Autonomous Systems',
    'Machine Learning',
    'Data Science',
    'AI Agents',
    'Cloud Computing',
    'Predictive Modeling',
  ],
  sameAs: [
    'https://github.com/Gustavjiversen01',
    'https://www.linkedin.com/in/gustav-jes-iversen-663641218/',
  ],
};
---

<BaseLayout
  title="About | Gustav Jes Iversen"
  description="B.Sc. in ML & Data Science, pursuing M.Sc. Autonomous Systems at DTU. Founder of HAVEN Intelligence. Building AI that ships to production."
  jsonLd={jsonLd}
>
  <!-- Intro -->
  <Section class="pt-8">
    <div class="max-w-3xl">
      <h1 class="font-sans text-3xl sm:text-5xl font-bold tracking-tight text-text-primary">
        About
      </h1>
      <p class="mt-6 text-base sm:text-lg text-text-secondary leading-relaxed max-w-2xl">
        I hold a B.Sc. in Machine Learning &amp; Data Science from the University of Copenhagen and am currently pursuing an M.Sc. in Autonomous Systems at DTU. As founder of HAVEN Intelligence, I help Danish businesses integrate AI into their operations. With 1.5 years of hands-on AI integration at GN, I build AI that ships to production.
      </p>
    </div>
  </Section>

  <!-- Experience -->
  <Section bg="secondary">
    <div class="max-w-3xl">
      <h2 class="font-sans text-2xl sm:text-3xl font-bold tracking-tight text-text-primary mb-8">
        Experience
      </h2>
      <div class="grid grid-cols-1 gap-6">
        <!-- HAVEN Intelligence -->
        <div class="border border-border bg-bg-elevated rounded-xl p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1 h-10 w-10 rounded-lg bg-accent-500/10 flex items-center justify-center">
              <svg class="h-5 w-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-text-primary tracking-tight">Founder & AI Consultant</h3>
              <p class="text-sm text-accent-400 mt-1">HAVEN Intelligence</p>
              <p class="text-sm text-text-muted mt-1">2024 - Present</p>
              <p class="mt-3 text-text-secondary text-sm leading-relaxed">
                Founded AI consulting company. Helps Danish businesses integrate AI agents, ML models, and cloud solutions. Developed AI curriculum for Fionia Maritime Academy.
              </p>
            </div>
          </div>
        </div>

        <!-- GN -->
        <div class="border border-border bg-bg-elevated rounded-xl p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1 h-10 w-10 rounded-lg bg-accent-500/10 flex items-center justify-center">
              <svg class="h-5 w-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-text-primary tracking-tight">Student Assistant in Core Cloud</h3>
              <p class="text-sm text-accent-400 mt-1">GN</p>
              <p class="text-sm text-text-muted mt-1">2024 - 2026</p>
              <p class="mt-3 text-text-secondary text-sm leading-relaxed">
                Built AI integrations for leading hearing technology company. Predictive modeling and data pipeline automation.
              </p>
            </div>
          </div>
        </div>

        <!-- DIKU Applied -->
        <div class="border border-border bg-bg-elevated rounded-xl p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1 h-10 w-10 rounded-lg bg-accent-500/10 flex items-center justify-center">
              <svg class="h-5 w-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-text-primary tracking-tight">Co-Founder & Lead Organizer</h3>
              <p class="text-sm text-accent-400 mt-1">DIKU Applied &middot; DIKU - UCPH</p>
              <p class="text-sm text-text-muted mt-1">November 2024 - Present</p>
              <p class="mt-3 text-text-secondary text-sm leading-relaxed">
                Established and spearhead 'DIKU Applied,' a student-led organization focused on bridging academic computer science theory with practical application. We organize and host regular hackathon-style events where students collaborate to build prototypes and gain real-world skills.
              </p>
            </div>
          </div>
        </div>

        <!-- Fionia Maritime Academy -->
        <div class="border border-border bg-bg-elevated rounded-xl p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1 h-10 w-10 rounded-lg bg-accent-500/10 flex items-center justify-center">
              <svg class="h-5 w-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-text-primary tracking-tight">AI Consultant</h3>
              <p class="text-sm text-accent-400 mt-1">Fionia Maritime Academy</p>
              <p class="text-sm text-text-muted mt-1">2024</p>
              <p class="mt-3 text-text-secondary text-sm leading-relaxed">
                Implemented AI into their business operations. Created and taught their AI course for maritime professionals.
              </p>
            </div>
          </div>
        </div>

        <!-- Topsoe -->
        <div class="border border-border bg-bg-elevated rounded-xl p-6 sm:p-8">
          <div class="flex items-start gap-4">
            <div class="shrink-0 mt-1 h-10 w-10 rounded-lg bg-accent-500/10 flex items-center justify-center">
              <svg class="h-5 w-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-text-primary tracking-tight">IT Assistant in Strategy and Innovation</h3>
              <p class="text-sm text-accent-400 mt-1">Topsoe</p>
              <p class="text-sm text-text-muted mt-1">2021 - 2022</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Education -->
  <Section>
    <div class="max-w-3xl">
      <h2 class="font-sans text-2xl sm:text-3xl font-bold tracking-tight text-text-primary mb-8">
        Education
      </h2>
      <div class="space-y-8 max-w-2xl">
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
            <div class="w-px flex-1 bg-border"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-base font-bold text-text-primary tracking-tight">M.Sc. Autonomous Systems</h3>
            <p class="text-sm text-accent-400 mt-1">Technical University of Denmark (DTU)</p>
            <p class="text-sm text-text-muted mt-1">Expected 2028</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="h-3 w-3 rounded-full bg-accent-500"></div>
          </div>
          <div>
            <h3 class="text-base font-bold text-text-primary tracking-tight">B.Sc. Machine Learning & Data Science</h3>
            <p class="text-sm text-accent-400 mt-1">University of Copenhagen</p>
            <p class="text-sm text-text-muted mt-1">Completed 2026</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Contact + HAVEN -->
  <Section>
    <div class="max-w-3xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Get in Touch -->
        <div>
          <h2 class="font-sans text-2xl sm:text-3xl font-bold tracking-tight text-text-primary mb-6">
            Get in Touch
          </h2>
          <div class="space-y-4">
            <a href="mailto:Gustavjes0105@gmail.com" class="flex items-center gap-3 text-text-secondary hover:text-accent-400 transition-colors">
              <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-sm">Gustavjes0105@gmail.com</span>
            </a>
            <a href="https://github.com/Gustavjiversen01" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-secondary hover:text-accent-400 transition-colors">
              <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              <span class="text-sm">github.com/Gustavjiversen01</span>
            </a>
            <a href="https://www.linkedin.com/in/gustav-jes-iversen-663641218/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-secondary hover:text-accent-400 transition-colors">
              <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              <span class="text-sm">LinkedIn</span>
            </a>
          </div>
        </div>

        <!-- HAVEN Intelligence -->
        <div class="border border-border bg-bg-elevated rounded-xl p-6 sm:p-8 flex flex-col justify-center">
          <h3 class="text-base font-bold text-text-primary tracking-tight">HAVEN Intelligence</h3>
          <p class="mt-2 text-text-secondary text-sm leading-relaxed">
            AI consulting for Danish businesses. We build and deploy AI solutions that actually work.
          </p>
          <a
            href="https://havenintelligence.dk"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 text-sm text-accent-400 hover:text-accent-300 transition-colors"
          >
            havenintelligence.dk
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
