        <!-- Node 4: Text Output -->
        <rect x="615" y="5" width="160" height="80" rx="12" fill="#1a1a1f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" />
        <text x="695" y="38" fill="#e4be5a" font-size="13" font-family="Inter, system-ui, sans-serif" font-weight="600" text-anchor="middle">Text Output</text>
        <text x="695" y="58" fill="#8b8b93" font-size="11" font-family="Inter, system-ui, sans-serif" text-anchor="middle">at cursor position</text>
      </svg>

      <!-- Vertical (mobile) -->
      <svg class="block sm:hidden w-full max-w-[240px] mx-auto" viewBox="0 0 240 500" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Audio pipeline: Microphone 16kHz to Audio Buffer to faster-whisper int8 to Text Output">
        <!-- Node 1 -->
        <rect x="10" y="0" width="220" height="70" rx="12" fill="#1a1a1f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" />
