        <text x="85" y="58" fill="#8b8b93" font-size="11" font-family="Inter, system-ui, sans-serif" text-anchor="middle">16 kHz mono</text>

        <!-- Arrow 1-2 -->
        <line x1="175" y1="45" x2="198" y2="45" stroke="#d4a843" stroke-width="1" />
        <polyline points="194,41 200,45 194,49" fill="none" stroke="#d4a843" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />

        <!-- Node 2: Audio Buffer -->
        <rect x="205" y="5" width="170" height="80" rx="12" fill="#1a1a1f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" />
        <text x="290" y="38" fill="#e4be5a" font-size="13" font-family="Inter, system-ui, sans-serif" font-weight="600" text-anchor="middle">Audio Buffer</text>
        <text x="290" y="58" fill="#8b8b93" font-size="11" font-family="Inter, system-ui, sans-serif" text-anchor="middle">collections.deque</text>

        <!-- Arrow 2-3 -->
        <line x1="380" y1="45" x2="403" y2="45" stroke="#d4a843" stroke-width="1" />
        <polyline points="399,41 405,45 399,49" fill="none" stroke="#d4a843" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />

        <!-- Node 3: faster-whisper -->
        <rect x="410" y="5" width="170" height="80" rx="12" fill="#1a1a1f" stroke="rgba(255,255,255,0.08)" stroke-width="1.5" />
        <text x="495" y="38" fill="#e4be5a" font-size="13" font-family="Inter, system-ui, sans-serif" font-weight="600" text-anchor="middle">faster-whisper</text>
        <text x="495" y="58" fill="#8b8b93" font-size="11" font-family="Inter, system-ui, sans-serif" text-anchor="middle">int8 quantized</text>

        <!-- Arrow 3-4 -->
        <line x1="585" y1="45" x2="608" y2="45" stroke="#d4a843" stroke-width="1" />
