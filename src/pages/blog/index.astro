---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Blog | Gustav Jes Iversen"
  description="Technical writing on software development, AI engineering, and building for the web."
>
  <Section bg="primary">
    <h1 class="font-sans text-3xl sm:text-5xl font-bold tracking-tight text-text-primary">Blog</h1>
    <p class="text-text-secondary mt-3 max-w-2xl">Thoughts on software development, AI engineering, and lessons learned along the way.</p>

    {posts.length > 0 ? (
      <div class="space-y-6 max-w-3xl mt-10">
        {posts.map((post) => (
          <BlogPostCard post={post} />
        ))}
      </div>
    ) : (
      <p class="text-text-muted text-center py-12">No posts yet. Check back soon.</p>
    )}
  </Section>
</BaseLayout>
