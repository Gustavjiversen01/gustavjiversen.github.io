---
interface Props {
  id?: string;
  class?: string;
  bg?: 'primary' | 'secondary';
}

const { id, class: className = '', bg = 'primary' } = Astro.props;

const bgClasses = {
  primary: 'bg-bg-primary',
  secondary: 'bg-bg-secondary',
};
---

<section id={id} class:list={[bgClasses[bg], 'py-16 sm:py-24 section-fade-top', className]}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <slot />
  </div>
</section>
