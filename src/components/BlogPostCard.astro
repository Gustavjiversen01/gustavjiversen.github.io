---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const readingTime = Math.ceil((post.body?.split(/\s+/).length ?? 0) / 200);
const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${post.id}/`} class="group block border border-border bg-bg-elevated rounded-xl p-6 sm:p-8 hover:border-border-hover hover:bg-bg-hover transition-colors duration-150">
  <div class="flex items-center gap-3 text-xs font-medium uppercase tracking-[0.1em] text-text-muted mb-3">
    <time datetime={post.data.publishDate.toISOString().slice(0, 10)}>{formattedDate}</time>
    <span aria-hidden="true">--</span>
    <span>{readingTime} min read</span>
  </div>
  <h3 class="font-bold text-xl tracking-tight text-text-primary group-hover:text-accent-400 transition-colors duration-150 line-clamp-2">
    {post.data.title}
  </h3>
  <p class="text-sm text-text-secondary leading-relaxed mt-2 mb-4 line-clamp-3">
    {post.data.description}
  </p>
  <TagList tags={post.data.tags} />
</a>
