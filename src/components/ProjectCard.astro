---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<a href={`/projects/${project.id}/`} class="group block rounded-xl card-glow p-6 overflow-hidden">
  <h3 class="text-lg font-bold text-text-primary group-hover:text-accent-400 transition-colors duration-300 tracking-tight">
    {project.data.title}
  </h3>
  <p class="text-sm text-text-secondary leading-relaxed mt-2">
    {project.data.description}
  </p>
</a>
